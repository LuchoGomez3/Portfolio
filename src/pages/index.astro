---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getLangFromUrl, useTranslations } from "../i18n/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Helper function to get localized path
function getLocalizedPath(path: string) {
  if (lang === "es") {
    return path;
  }
  return `/${lang}${path}`;
}
---

<Layout>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <div class="px-4 md:px-10 lg:px-40 py-5">
        <div class="max-w-[960px] mx-auto">
          <!-- Hero Section -->
          <div class="py-10">
            <div
              class="flex flex-col gap-6 @[480px]:gap-8 md:flex-row-reverse md:items-center"
            >
              <!-- Profile Image -->
              <div
                class="w-full md:w-[400px] md:h-[400px] aspect-square bg-gray-300 dark:bg-gray-700 bg-center bg-no-repeat bg-cover rounded-xl shadow-lg flex items-center justify-center text-gray-500 dark:text-gray-400"
              >
                <span class="text-sm">{t("home.imagePlaceholder")}</span>
              </div>

              <!-- Hero Content -->
              <div class="flex flex-col gap-6 md:flex-1">
                <div class="flex flex-col gap-2 text-left">
                  <h1
                    class="text-text-light dark:text-text-dark text-4xl md:text-5xl font-black leading-tight tracking-[-0.033em]"
                  >
                    {t("home.title")}
                  </h1>
                  <h2
                    class="text-card-text-light dark:text-gray-300 text-base font-normal leading-normal"
                  >
                    {t("home.subtitle")}
                  </h2>
                </div>

                <!-- CTA Buttons -->
                <div class="flex flex-wrap gap-3">
                  <a
                    href={getLocalizedPath("/projects")}
                    class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 md:h-12 px-4 md:px-5 bg-primary text-white text-sm md:text-base font-bold leading-normal tracking-[0.015em] hover:bg-primary-hover transition-colors"
                  >
                    <span class="truncate">{t("home.viewProjects")}</span>
                  </a>
                  <a
                    href={getLocalizedPath("/about")}
                    class="flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 md:h-12 px-4 md:px-5 bg-gray-200 dark:bg-gray-800 text-text-light dark:text-text-dark text-sm md:text-base font-bold leading-normal tracking-[0.015em] hover:bg-gray-300 dark:hover:bg-gray-700 transition-colors"
                  >
                    <span class="truncate">{t("home.contactMe")}</span>
                  </a>
                </div>

                <!-- Social Links -->
                <div class="flex gap-4 flex-wrap">
                  <a
                    href="mailto:tu@email.com"
                    class="group"
                    aria-label="Email"
                  >
                    <div
                      class="rounded-full bg-gray-200 dark:bg-gray-800 p-3 group-hover:bg-primary/20 transition-colors"
                    >
                      <span
                        class="material-symbols-outlined text-text-light dark:text-text-dark"
                        style="font-size: 24px;">alternate_email</span
                      >
                    </div>
                  </a>
                  <a
                    href="https://www.linkedin.com/in/luciano-ariel-gomez-366292215"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group"
                    aria-label="LinkedIn"
                  >
                    <div
                      class="rounded-full bg-gray-200 dark:bg-gray-800 p-3 group-hover:bg-primary/20 transition-colors"
                    >
                      <svg
                        class="text-text-light dark:text-text-dark"
                        height="24"
                        viewBox="0 0 24 24"
                        width="24"
                      >
                        <path
                          d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                          fill="currentColor"></path>
                      </svg>
                    </div>
                  </a>
                  <a
                    href="https://github.com/LuchoGomez3"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group"
                    aria-label="GitHub"
                  >
                    <div
                      class="rounded-full bg-gray-200 dark:bg-gray-800 p-3 group-hover:bg-primary/20 transition-colors"
                    >
                      <svg
                        class="text-text-light dark:text-text-dark"
                        height="24"
                        viewBox="0 0 24 24"
                        width="24"
                      >
                        <path
                          d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                          fill="currentColor"></path>
                      </svg>
                    </div>
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Projects Section -->
          <section class="py-10">
            <h2
              class="text-text-light dark:text-text-dark text-[22px] font-bold leading-tight tracking-[-0.015em] px-4 pb-3 pt-5"
            >
              {t("home.projectsTitle")}
            </h2>
            <div
              class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 p-4"
            >
              <!-- Project Card 1 -->
              <div
                class="flex flex-col gap-3 pb-3 bg-card-light dark:bg-card-dark rounded-lg overflow-hidden shadow-md transition-transform hover:scale-105"
              >
                <div
                  class="w-full bg-gray-300 dark:bg-gray-700 aspect-video flex items-center justify-center text-gray-500 dark:text-gray-400"
                >
                  <span class="text-sm"
                    >{t("home.projectImagePlaceholder")} 1</span
                  >
                </div>
                <div class="p-4">
                  <p
                    class="text-text-light dark:text-text-dark text-lg font-medium leading-normal"
                  >
                    {t("home.projectOne.title")}
                  </p>
                  <p
                    class="text-card-text-light dark:text-gray-300 text-sm font-normal leading-normal"
                  >
                    {t("home.projectOne.description")}
                  </p>
                </div>
              </div>

              <!-- Project Card 2 -->
              <div
                class="flex flex-col gap-3 pb-3 bg-card-light dark:bg-card-dark rounded-lg overflow-hidden shadow-md transition-transform hover:scale-105"
              >
                <div
                  class="w-full bg-gray-300 dark:bg-gray-700 aspect-video flex items-center justify-center text-gray-500 dark:text-gray-400"
                >
                  <span class="text-sm"
                    >{t("home.projectImagePlaceholder")} 2</span
                  >
                </div>
                <div class="p-4">
                  <p
                    class="text-text-light dark:text-text-dark text-lg font-medium leading-normal"
                  >
                    {t("home.projectTwo.title")}
                  </p>
                  <p
                    class="text-card-text-light dark:text-gray-300 text-sm font-normal leading-normal"
                  >
                    {t("home.projectTwo.description")}
                  </p>
                </div>
              </div>

              <!-- Project Card 3 -->
              <div
                class="flex flex-col gap-3 pb-3 bg-card-light dark:bg-card-dark rounded-lg overflow-hidden shadow-md transition-transform hover:scale-105"
              >
                <div
                  class="w-full bg-gray-300 dark:bg-gray-700 aspect-video flex items-center justify-center text-gray-500 dark:text-gray-400"
                >
                  <span class="text-sm"
                    >{t("home.projectImagePlaceholder")} 3</span
                  >
                </div>
                <div class="p-4">
                  <p
                    class="text-text-light dark:text-text-dark text-lg font-medium leading-normal"
                  >
                    {t("home.projectThree.title")}
                  </p>
                  <p
                    class="text-card-text-light dark:text-gray-300 text-sm font-normal leading-normal"
                  >
                    {t("home.projectThree.description")}
                  </p>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
