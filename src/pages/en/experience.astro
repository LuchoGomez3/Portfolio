---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("meta.experienceTitle")}>
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <div class="px-4 md:px-10 lg:px-20 xl:px-40 py-10 md:py-20">
        <div class="max-w-[960px] mx-auto">
          <!-- Page Header -->
          <h2
            class="text-text-light dark:text-text-dark text-3xl md:text-4xl font-bold leading-tight tracking-tight text-center"
          >
            {t("experience.title")}
          </h2>
          <p
            class="text-center mt-4 text-lg text-card-text-light dark:text-gray-400"
          >
            {t("experience.subtitle")}
          </p>

          <!-- Timeline -->
          <div class="relative mt-12 px-4">
            <!-- Vertical line -->
            <div
              class="absolute left-1/2 top-0 h-full w-0.5 bg-timeline-line dark:bg-gray-700 transform -translate-x-1/2"
            >
            </div>

            <!-- Timeline Items -->
            <div class="space-y-16">
              <!-- Item 1 -->
              <div
                class="relative flex items-center timeline-item justify-end md:justify-normal"
              >
                <div class="w-full md:w-1/2 md:pr-8">
                  <div
                    class="p-6 bg-card-light dark:bg-card-dark rounded-xl shadow-md hover:shadow-xl transition-all duration-300 ease-in-out timeline-card"
                  >
                    <p class="text-primary text-sm font-semibold">
                      {t("experience.job1.period")}
                    </p>
                    <h3
                      class="text-xl font-bold mt-1 text-text-light dark:text-text-dark"
                    >
                      {t("experience.job1.title")}
                    </h3>
                    <p
                      class="text-md font-medium text-gray-700 dark:text-gray-300"
                    >
                      {t("experience.job1.company")}
                    </p>
                    <p
                      class="mt-3 text-card-text-light dark:text-gray-400 text-sm"
                    >
                      {t("experience.job1.description")}
                    </p>
                  </div>
                </div>
                <div
                  class="absolute left-1/2 -translate-x-1/2 w-5 h-5 rounded-full bg-white dark:bg-gray-800 border-4 border-timeline-line dark:border-gray-700 timeline-node transition-all duration-300 ease-in-out"
                >
                </div>
                <div class="hidden md:block w-1/2"></div>
              </div>

              <!-- Item 2 -->
              <div
                class="relative flex items-center timeline-item justify-end md:justify-normal"
              >
                <div class="hidden md:block w-1/2"></div>
                <div
                  class="absolute left-1/2 -translate-x-1/2 w-5 h-5 rounded-full bg-white dark:bg-gray-800 border-4 border-timeline-line dark:border-gray-700 timeline-node transition-all duration-300 ease-in-out"
                >
                </div>
                <div class="w-full md:w-1/2 md:pl-8">
                  <div
                    class="p-6 bg-card-light dark:bg-card-dark rounded-xl shadow-md hover:shadow-xl transition-all duration-300 ease-in-out timeline-card"
                  >
                    <p class="text-primary text-sm font-semibold">
                      {t("experience.job2.period")}
                    </p>
                    <h3
                      class="text-xl font-bold mt-1 text-text-light dark:text-text-dark"
                    >
                      {t("experience.job2.title")}
                    </h3>
                    <p
                      class="text-md font-medium text-gray-700 dark:text-gray-300"
                    >
                      {t("experience.job2.company")}
                    </p>
                    <p
                      class="mt-3 text-card-text-light dark:text-gray-400 text-sm"
                    >
                      {t("experience.job2.description")}
                    </p>
                  </div>
                </div>
              </div>

              <!-- Item 3 -->
              <div
                class="relative flex items-center timeline-item justify-end md:justify-normal"
              >
                <div class="w-full md:w-1/2 md:pr-8">
                  <div
                    class="p-6 bg-card-light dark:bg-card-dark rounded-xl shadow-md hover:shadow-xl transition-all duration-300 ease-in-out timeline-card"
                  >
                    <p class="text-primary text-sm font-semibold">
                      {t("experience.job3.period")}
                    </p>
                    <h3
                      class="text-xl font-bold mt-1 text-text-light dark:text-text-dark"
                    >
                      {t("experience.job3.title")}
                    </h3>
                    <p
                      class="text-md font-medium text-gray-700 dark:text-gray-300"
                    >
                      {t("experience.job3.company")}
                    </p>
                    <p
                      class="mt-3 text-card-text-light dark:text-gray-400 text-sm"
                    >
                      {t("experience.job3.description")}
                    </p>
                  </div>
                </div>
                <div
                  class="absolute left-1/2 -translate-x-1/2 w-5 h-5 rounded-full bg-white dark:bg-gray-800 border-4 border-timeline-line dark:border-gray-700 timeline-node transition-all duration-300 ease-in-out"
                >
                </div>
                <div class="hidden md:block w-1/2"></div>
              </div>
            </div>
          </div>

          <!-- Scroll Indicator -->
          <div
            class="mt-20 text-center text-gray-500 dark:text-gray-400 flex justify-center items-center flex-col"
          >
            <p>{t("experience.scrollMore")}</p>
            <span class="material-symbols-outlined mt-2 animate-bounce">
              keyboard_arrow_down
            </span>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .timeline-item:hover .timeline-node {
    background-color: #13a4ec;
    transform: scale(1.2);
  }

  .timeline-item:hover .timeline-card {
    transform: translateY(-4px);
  }
</style>
