---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout title="Habilidades - Luciano Gomez">
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <div class="px-4 md:px-20 lg:px-40 py-5">
        <div class="max-w-[960px] mx-auto">
          <!-- Page Title -->
          <h2
            class="text-text-light dark:text-white text-3xl font-bold leading-tight tracking-tighter px-4 pb-3 pt-5"
          >
            Mis Habilidades
          </h2>

          <!-- Filter Tabs -->
          <div class="flex gap-3 p-3 flex-wrap pr-4">
            <button
              class="filter-btn active flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="all"
            >
              <p class="text-sm font-medium leading-normal">Todos</p>
            </button>
            <button
              class="filter-btn flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg border pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="design"
            >
              <p class="text-sm font-medium leading-normal">Diseño</p>
            </button>
            <button
              class="filter-btn flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg border pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="development"
            >
              <p class="text-sm font-medium leading-normal">Desarrollo</p>
            </button>
            <button
              class="filter-btn flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg border pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="tools"
            >
              <p class="text-sm font-medium leading-normal">Herramientas</p>
            </button>
          </div>

          <!-- Skills Grid -->
          <div
            class="grid grid-cols-[repeat(auto-fit,minmax(158px,1fr))] gap-4 p-4"
          >
            <!-- Design Skills -->
            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="design"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >design_services</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Diseño UX/UI
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="design"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >person_search</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Investigación de Usuario
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="design"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >widgets</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Prototipado
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="design"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >touch_app</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Diseño de Interacción
              </h2>
            </div>

            <!-- Development Skills -->
            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="development"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >code</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                HTML5 & CSS3
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="development"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >javascript</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                JavaScript (React/Vue)
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="development"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >devices</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Desarrollo Responsive
              </h2>
            </div>

            <!-- Tools -->
            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="tools"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >folder_managed</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Git
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="tools"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >photo_filter</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Figma
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="tools"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >pinch_zoom_in</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Adobe XD
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="tools"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >terminal</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Visual Studio Code
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="tools"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >view_kanban</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Jira
              </h2>
            </div>
          </div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<style>
  .filter-btn {
    @apply bg-background-light dark:bg-background-dark border-gray-200 dark:border-gray-700 text-text-light dark:text-white;
  }

  .filter-btn:hover {
    @apply bg-primary/20 border-primary/20;
  }

  .filter-btn.active {
    @apply bg-primary/20 border-primary/20 text-primary border-transparent;
  }

  .skill-card {
    @apply border-gray-200 dark:border-gray-700;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filterButtons = document.querySelectorAll(".filter-btn");
    const skillCards = document.querySelectorAll(".skill-card");

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const filter = button.getAttribute("data-filter");

        // Update active button
        filterButtons.forEach((btn) => btn.classList.remove("active"));
        button.classList.add("active");

        // Filter cards
        skillCards.forEach((card) => {
          const category = card.getAttribute("data-category");

          if (filter === "all" || category === filter) {
            card.style.display = "flex";
          } else {
            card.style.display = "none";
          }
        });
      });
    });
  });
</script>
