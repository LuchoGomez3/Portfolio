---

<Layout title="Habilidades - Luciano Gomez">
  <div class="min-h-screen flex flex-col">
    <Header />

    <main class="flex-1">
      <div class="px-4 md:px-20 lg:px-40 py-5">
        <div class="max-w-[960px] mx-auto">
          <!-- Page Title -->
          <h2
            class="text-text-light dark:text-white text-3xl font-bold leading-tight tracking-tighter px-4 pb-3 pt-5"
          >
            Mis Habilidades
          </h2>

          <!-- Filter Tabs -->
          <div class="flex gap-3 p-3 flex-wrap pr-4">
            <button
              class="filter-btn active flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="all"
            >
              <p class="text-sm font-medium leading-normal">Todos</p>
            </button>
            <button
              class="filter-btn flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg border pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="frontend"
            >
              <p class="text-sm font-medium leading-normal">Frontend</p>
            </button>
            <button
              class="filter-btn flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg border pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="backend"
            >
              <p class="text-sm font-medium leading-normal">Backend</p>
            </button>
            <button
              class="filter-btn flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg border pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="learning"
            >
              <p class="text-sm font-medium leading-normal">Aprendiendo</p>
            </button>
            <button
              class="filter-btn flex h-8 shrink-0 items-center justify-center gap-x-2 rounded-lg border pl-4 pr-4 cursor-pointer transition-colors"
              data-filter="tools"
            >
              <p class="text-sm font-medium leading-normal">Herramientas</p>
            </button>
          </div>

          <!-- Skills Grid -->
          <div
            class="grid grid-cols-[repeat(auto-fit,minmax(158px,1fr))] gap-4 p-4"
          >
            <!-- Design Skills -->
            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="frontend"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >design_services</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Diseño UX/UI
              </h2>
            </div>

            <!--  Frontend Skills -->
            {
              SKILLS.map(({ title, image, category }) => (
                <div
                  class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
                  data-category={category}
                >
                  <div class="flex flex-col items-center text-center">
                    {typeof image === "string" ? (
                      <img
                        src={image}
                        alt={title}
                        class="w-10 h-10 sm:w-12 sm:h-12 mb-1 sm:mb-2"
                      />
                    ) : (
                      <>
                        <img
                          src={image.light}
                          alt={title}
                          class="w-10 h-10 sm:w-12 sm:h-12 mb-1 sm:mb-2 block dark:hidden"
                        />
                        <img
                          src={image.dark}
                          alt={title}
                          class="w-10 h-10 sm:w-12 sm:h-12 mb-1 sm:mb-2 hidden dark:block"
                        />
                      </>
                    )}
                    <h2 class="text-text-light dark:text-white text-base font-bold leading-tight">
                      {title}
                    </h2>
                  </div>
                </div>
              ))
            }

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="frontend"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >person_search</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Investigación de Usuario
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="frontend"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >widgets</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
              >
                Prototipado
              </h2>
            </div>

            <div
              class="skill-card flex flex-1 flex-col gap-3 rounded-xl border bg-card-light dark:bg-background-dark p-4 items-center justify-center text-center transform transition-all duration-300 hover:scale-105 hover:shadow-lg hover:border-primary"
              data-category="frontend"
            >
              <span class="material-symbols-outlined text-primary text-4xl"
                >touch_app</span
              >
              <h2
                class="text-text-light dark:text-white text-base font-bold leading-tight"
