---
import { getLangFromUrl, useTranslations } from "../i18n/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer
  class="py-10 mt-10 border-t border-solid border-gray-200 dark:border-gray-700"
>
  <div
    class="max-w-7xl mx-auto text-center text-card-text-light dark:text-card-text-dark text-sm"
  >
    <p>© {currentYear} Luciano Gomez. {t("footer.copyright")}</p>
  </div>
</footer>
