---
import ThemeToggle from "./ThemeToggle";
import LanguageSwitcher from "./LanguageSwitcher";
import { getLangFromUrl, useTranslations } from "../i18n/i18n";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

// Helper function to get localized path
function getLocalizedPath(path: string) {
  if (lang === "es") {
    return path;
  }
  return `/${lang}${path}`;
}
---

<header
  class="border-b border-solid border-gray-200 dark:border-gray-700 px-4 sm:px-10 py-3"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo and Name -->
    <a
      href={getLocalizedPath("/")}
      class="flex items-center gap-4 text-text-light dark:text-text-dark hover:opacity-80 transition-opacity"
    >
      <div class="size-6">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M22 13.478v4.522a3 3 0 0 1 -3 3h-14a3 3 0 0 1 -3 -3v-4.522l.553 .277a20.999 20.999 0 0 0 18.897 -.002l.55 -.275zm-8 -11.478a3 3 0 0 1 3 3v1h2a3 3 0 0 1 3 3v2.242l-1.447 .724a19.002 19.002 0 0 1 -16.726 .186l-.647 -.32l-1.18 -.59v-2.242a3 3 0 0 1 3 -3h2v-1a3 3 0 0 1 3 -3h4zm-2 8a1 1 0 0 0 -1 1a1 1 0 1 0 2 .01c0 -.562 -.448 -1.01 -1 -1.01zm2 -6h-4a1 1 0 0 0 -1 1v1h6v-1a1 1 0 0 0 -1 -1z"></path>
        </svg>
      </div>
      <h2 class="text-lg font-bold leading-tight tracking-[-0.015em]">
        Luciano Gomez
      </h2>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex flex-1 justify-end gap-8">
      <div class="flex items-center gap-9">
        <a
          href={getLocalizedPath("/projects")}
          class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/projects") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
        >
          {t("nav.projects")}
        </a>
        <a
          href={getLocalizedPath("/skills")}
          class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/skills") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
        >
          {t("nav.skills")}
        </a>
        <a
          href={getLocalizedPath("/experience")}
          class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/experience") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
        >
          {t("nav.experience")}
        </a>
        <a
          href={getLocalizedPath("/about")}
          class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/about") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
        >
          {t("nav.about")}
        </a>
        <LanguageSwitcher
          client:load
          currentLang={lang}
          currentPath={currentPath}
        />
        <ThemeToggle client:load />
      </div>
    </nav>

    <!-- Mobile Menu Button -->
    <div class="md:hidden flex items-center gap-2">
      <LanguageSwitcher
        client:load
        currentLang={lang}
        currentPath={currentPath}
      />
      <ThemeToggle client:load />
      <button
        id="mobile-menu-button"
        class="flex items-center justify-center p-2 rounded-lg bg-background-light dark:bg-background-dark text-text-light dark:text-text-dark hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
        aria-label="Toggle menu"
      >
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden mt-4 pb-4 border-t border-gray-200 dark:border-gray-700 pt-4"
  >
    <div class="flex flex-col gap-4">
      <a
        href={getLocalizedPath("/projects")}
        class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/projects") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
      >
        {t("nav.projects")}
      </a>
      <a
        href={getLocalizedPath("/skills")}
        class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/skills") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
      >
        {t("nav.skills")}
      </a>
      <a
        href={getLocalizedPath("/experience")}
        class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/experience") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
      >
        {t("nav.experience")}
      </a>
      <a
        href={getLocalizedPath("/about")}
        class={`text-sm font-medium leading-normal transition-colors ${currentPath === getLocalizedPath("/about") ? "text-primary" : "text-text-light dark:text-text-dark hover:text-primary"}`}
      >
        {t("nav.about")}
      </a>
    </div>
  </nav>
</header>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const button = document.getElementById("mobile-menu-button");
    const menu = document.getElementById("mobile-menu");

    button?.addEventListener("click", () => {
      menu?.classList.toggle("hidden");
    });
  });
</script>
